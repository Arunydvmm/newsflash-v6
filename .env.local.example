# ============================================
# NewsFlash V6 — Environment Variables
# Copy this file to .env.local for development
# Add ALL these in Render Dashboard > Environment
# ============================================

# ── Database (MongoDB Atlas) ──────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/newsflash?retryWrites=true&w=majority

# ── Authentication ────────────────────────────
# Generate a strong random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this

# ── Cloudinary (Image Storage) ────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Cricket API (CricketData.org) ─────────────
# No longer required — cricket now uses LiveScore6 via RapidAPI
# CRICKETDATA_API_KEY=your_cricketdata_org_api_key

# ── RapidAPI (Cricket + Jobs) ─────────────────
# Get your key at: https://rapidapi.com/developer/dashboard
# Used for: LiveScore6 cricket live scores + Active Jobs DB API
# NEVER expose in frontend — backend only
RAPIDAPI_KEY=your_rapidapi_key_here

# ── IndianAPI.in (Legacy — replaced by RapidAPI) ──
# INDIANAPI_KEY=your_old_key_here

# ── Email (Gmail SMTP) ────────────────────────
# Step 1: Enable 2FA on your Gmail account
# Step 2: Go to myaccount.google.com/apppasswords
# Step 3: Generate an App Password for "Mail"
# Step 4: Use that 16-char password below (NOT your regular Gmail password)
GMAIL_USER=65arunyadav65@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Site URL ──────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://newsflash-v6.onrender.com

# ── Seed Secret (one-time DB setup) ──────────
# After deploy, visit: /api/seed?key=YOUR_SEED_SECRET
# This creates the SuperAdmin account
SEED_SECRET=your_seed_secret_key_change_this

# ── Node Environment ──────────────────────────
NODE_ENV=production
